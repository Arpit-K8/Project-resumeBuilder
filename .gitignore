# Monorepo-wide ignores

# Dependency directories
client/node_modules/
server/node_modules/

# Build output
client/dist/
client/dist-ssr/
server/dist/
server/build/

# Coverage output
client/coverage/
server/coverage/
.nyc_output/

# Environment and local config
client/.env
client/.env.*
!client/.env.example
server/.env
server/.env.*
!server/.env.example
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
